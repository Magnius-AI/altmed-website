# Database
POSTGRES_DB=altmed
POSTGRES_USER=altmed
POSTGRES_PASSWORD=altmed_dev_password

# Backend
NODE_ENV=development
API_PREFIX=api
# Use localhost when running backend commands from your terminal.
# Docker Compose overrides this to `postgres` inside containers.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=altmed
DATABASE_USER=altmed
DATABASE_PASSWORD=altmed_dev_password
JWT_SECRET=GENERATE_STRONG_SECRET_256BIT
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=GENERATE_STRONG_REFRESH_SECRET_256BIT
JWT_REFRESH_EXPIRES_IN=30d
FRONTEND_URL=http://localhost:3000
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_V3_SECRET
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=info@altmedfirst.com
EMAIL_PASS=YOUR_EMAIL_APP_PASSWORD
CONTACT_FORM_RECIPIENT=info@altmedfirst.com
ADMIN_ALERT_EMAIL=admin@altmedfirst.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_V3_SITE_KEY
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_MAPS_KEY
NEXTAUTH_SECRET=GENERATE_STRONG_SECRET
NEXTAUTH_URL=http://localhost:3000
