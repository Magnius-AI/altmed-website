{
  "family": "altmed-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "X86_64"
  },
  "executionRoleArn": "arn:aws:iam::245324547486:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "245324547486.dkr.ecr.us-east-1.amazonaws.com/altmed-website-frontend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "BACKEND_URL_INTERNAL",
          "value": "http://BACKEND_SERVICE_OR_INTERNAL_ALB:3001"
        },
        {
          "name": "API_URL_INTERNAL",
          "value": "https://PUBLIC_APP_URL"
        },
        {
          "name": "NEXT_PUBLIC_API_URL",
          "value": "https://PUBLIC_APP_URL"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/altmed-frontend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
